# ==========================================
# KONFIGURASI ENVIRONMENT VARIABLES ABJAD.IN
# ==========================================

# -----------------
# 1. Google Cloud
# -----------------
GOOGLE_CLOUD_PROJECT=rapid-domain-495803-i8
GOOGLE_CLOUD_REGION=asia-southeast2

# -----------------
# 2. AI (Gemini)
# -----------------
# Dapatkan di: https://aistudio.google.com
GEMINI_API_KEY=

# -----------------
# 3. Security APIs
# -----------------
# Dapatkan di: Google Cloud Console (APIs & Services -> Credentials)
GOOGLE_SAFE_BROWSING_API_KEY=
WEB_RISK_API_KEY=

# Dapatkan di: https://phishtank.com/api_info.php
PHISHTANK_API_KEY=

# Dapatkan di: https://dev.bitly.com
BITLY_API_KEY=

# (Gratis, tidak perlu key)
RDAP_API_URL=https://rdap.org

# -----------------
# 4. WhatsApp Bot (Opsional/Tier 2)
# -----------------
# Dapatkan di: Meta for Developers (WhatsApp Cloud API)
WA_CLOUD_API_TOKEN=
WA_PHONE_NUMBER_ID=
WA_VERIFY_TOKEN=

# -----------------
# 5. Telegram Bot (Opsional/Tier 2)
# -----------------
# Dapatkan dari: @BotFather di Telegram
TELEGRAM_BOT_TOKEN=

# -----------------
# 6. Keamanan Internal
# -----------------
# String acak untuk keperluan internal security (Token Trap)
HONEY_TOKEN_SECRET=

# -----------------
# 7. Konfigurasi App
# -----------------
PORT=8080
NODE_ENV=development

# Playwright butuh Chromium di container (ada risiko memori di Cloud Run)
# Aktifkan HANYA jika layer Axios+Cheerio sudah stabil (default: false)
PLAYWRIGHT_ENABLED=false

# Gunakan Lookup API SAJA (gratis s.d 100k/bulan).
# JANGAN ubah ke false (Update API biayanya $50/1000 call).
WEB_RISK_LOOKUP_ONLY=true
